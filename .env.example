# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (Claude Haiku 4.5 for enrichment)
ANTHROPIC_API_KEY=

# Voyage AI (for embeddings - optional, enables semantic dedup)
VOYAGE_API_KEY=

# Secret for cron endpoint auth (any long random string)
CRON_SECRET=

# Public site URL (used for OG tags, push notifications)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: GitHub token (raises trending/search rate limits 60/hr -> 5000/hr)
GITHUB_TOKEN=

# Optional: Reddit API credentials (if skipped, falls back to public .json endpoints)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ai-news-feed/0.1
