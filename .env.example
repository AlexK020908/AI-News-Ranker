# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (Claude Haiku 4.5 for enrichment)
ANTHROPIC_API_KEY=

# Voyage AI (for embeddings - optional, enables semantic dedup)
# 200M free tokens on signup (~6 months at this app's volume); then $0.06/M.
VOYAGE_API_KEY=

# Secret for cron endpoint auth (any long random string)
CRON_SECRET=

# Days of news to retain. Items older than this are auto-pruned at ingest time.
# Default: 14. Raise for more history (and more Haiku spend on backfill).
ITEM_RETENTION_DAYS=14

# Public site URL (used for OG tags, push notifications)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: GitHub token (raises trending/search rate limits 60/hr -> 5000/hr)
GITHUB_TOKEN=

# Optional: Semantic Scholar API key (higher rate limits for arXiv citation enrichment)
SEMANTIC_SCHOLAR_API_KEY=

